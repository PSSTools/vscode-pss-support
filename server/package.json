{
    "name": "pss-language-server",
    "description": "PSS Language Server",
    "version": "1.0.0",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "antlr4ng": "^3.0.4",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@vitest/coverage-v8": "^2.1.0",
        "antlr4ng-cli": "^2.0.0",
        "typescript": "^5.4.0",
        "vitest": "^2.1.0"
    },
    "scripts": {
        "build": "tsc -b",
        "build:grammar": "antlr4ng -Dlanguage=TypeScript -visitor -listener -o src/generated ../packages/zuspec-fe-pss/src/PSSLexer.g4 ../packages/zuspec-fe-pss/src/PSSParser.g4",
        "test:core": "vitest run --project core",
        "test:lsp": "vitest run --project lsp",
        "test:bench": "vitest bench",
        "test": "vitest run"
    }
}
