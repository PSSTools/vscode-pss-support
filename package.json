{
    "name": "vscode-pss-support",
    "version": "0.3.0",
    "displayName": "VSCode Accellera PSS",
    "description": "VSCode support for the Accellera Portable Stimulus Specification (PSS) language",
    "publisher": "matthew-ballance",
    "license": "Apache 2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/psstools/vscode-pss-support"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "icon": "images/icon.png",
    "badges": [
        {
            "url": "https://dev.azure.com/mballance/psstools/_apis/build/status/PSSTools.vscode-pss-support?branchName=master",
            "href": "https://dev.azure.com/mballance/psstools/_build/latest?definitionId=21&branchName=master",
            "description": "Build Status"
        }
    ],
    "keywords": [
        "portable stimulus",
        "pss",
        "Accellera"
    ],
    "activationEvents": [
        "onLanguage:pss"
    ],
    "main": "./client/out/extension",
    "contributes": {
        "languages": [
            {
                "id": "pss",
                "aliases": [
                    "portable-stimulus",
                    "pss"
                ],
                "extensions": [
                    ".pss"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "snippets": [
            {
                "language": "pss",
                "path": "./snippets/pss.json"
            }
        ],
        "grammars": [
            {
                "language": "pss",
                "scopeName": "source.pss",
                "path": "./syntaxes/pss.tmLanguage.json",
                "embeddedLanguages": {
                    "meta.embedded.block.c": "c",
                    "meta.embedded.block.sv": "systemverilog"
                }
            }
        ],
        "configuration": {
            "type": "object",
            "title": "PSS configuration",
            "properties": {
                "pss.maxNumberOfProblems": {
                    "scope": "resource",
                    "type": "number",
                    "default": 100,
                    "description": "Controls maximum number of errors produced per file"
                },
                "pss.trace.server": {
                    "scope": "window",
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces communication between VSCode and LSP"
                }
            }
        },
        "commands": [
            {
                "command": "pss.showActivityDiagram",
                "title": "PSS: View Activity Diagram",
                "category": "PSS"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "when": "resourceLangId == pss",
                    "command": "pss.showActivityDiagram",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "npm run build:grammar && tsc -b",
        "build:grammar": "cd server && npm run build:grammar",
        "compile": "tsc -b",
        "watch": "tsc -b -w",
        "test": "npm run test:core && npm run test:lsp",
        "test:core": "cd server && npm run test:core",
        "test:lsp": "cd server && npm run test:lsp",
        "test:bench": "cd server && npm run test:bench",
        "lint": "eslint server/src/core/ --ext .ts",
        "postinstall": "cd client && npm install && cd ../server && npm install"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.56.0",
        "typescript": "^5.4.0"
    }
}
